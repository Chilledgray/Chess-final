#:import Factory kivy.factory.Factory


<PlayerNamePopup@Popup>:
    title: "Enter Player Names"
    size_hint: 0.6, 0.6
    auto_dismiss: False

    BoxLayout:
        orientation: 'vertical'

        TextInput:
            id: white_input
            hint_text: "White Player"
            multiline: False

        Label:
            text: ""

        TextInput:
            id: black_input
            hint_text: "Black Player"
            multiline: False


        Label:
            text: ""

        Button:
            text: "Start Game"
            font_size: 40
            font_name: "ARCADECLASSIC"
            on_press:
                app.start_game_with_names(white_input.text.strip(), black_input.text.strip())
                root.dismiss()


<StatPop@Popup>:

    title: "Search Player"

    size_hint: .5,.5
    pos_hint: {"x": 0.25, "top":.7}

    BoxLayout:
        orientation: 'vertical'

        TextInput:
            id: text_input
            size_hint: 1,.5
            hint_text: "Search Player"
            multiline: False

        Label:
            text:""


        Button:
            text: "submit"
            on_press: app.widget_m.get_player_name(root)
            on_press: root.dismiss()
            size_hint: 1,.3



<Menu>:

    canvas.before:
        Rectangle:
            size: self.size
            source: "homescreen.jpg"

    Label:
        text: "C H E S S"
        font_name: "ARCADECLASSIC"
        font_size: 200
        pos_hint: {"center_x": .5, "center_y": .8}

    Button:
        text: "play"
        font_name: "ARCADECLASSIC"
        font_size: 30
        pos_hint: {"center_x": .5, "center_y": .6}
        size_hint: .2,.1
        background_color: 0.702, 0.588, 0.961, 1
        on_press: Factory.PlayerNamePopup().open()


    Button:
        text: "stats"
        font_name: "ARCADECLASSIC"
        font_size: 30
        pos_hint: {"center_x": .5, "center_y": .45}
        size_hint: .2,.1
        background_color: 0.702, 0.588, 0.961, 1
        on_press: root.parent.show_stats()
        on_release: Factory.StatPop().open()

    Button:
        text: "Quit"
        font_name: "ARCADECLASSIC"
        font_size: 30
        pos_hint: {"center_x": .5, "center_y": .3}
        size_hint: .2,.1
        background_color: 0.702, 0.588, 0.961, 1
        on_press: app.stop()



